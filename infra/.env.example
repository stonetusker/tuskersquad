# ════════════════════════════════════════════════════════════════════
# TuskerSquad — Environment Variables
# Copy to: cp infra/.env.example infra/.env
# ════════════════════════════════════════════════════════════════════

# ── Ollama (LLM backend) ─────────────────────────────────────────────
# Mac/Windows: host.docker.internal resolves to the host automatically.
# Linux: replace with your actual host IP, e.g. http://192.168.1.100:11434
OLLAMA_URL=http://host.docker.internal:11434

# ── Gitea integration ─────────────────────────────────────────────────
# GITEA_URL: internal Docker URL — services talk to Gitea by container name.
# Do not change this unless you are running Gitea outside Docker.
GITEA_URL=http://tuskersquad-gitea:3000

# GITEA_TOKEN: personal access token so TuskerSquad can post PR comments,
# set labels, and trigger merges.
# Generate at: http://localhost:3000/user/settings/applications
# Permissions needed: repository (read+write), issue (read+write)
GITEA_TOKEN=

# GITEA_WEBHOOK_SECRET: optional shared secret for webhook signature validation.
# If you set a "Secret" in Gitea's webhook settings, set the same value here.
# Leave blank if you did not set a secret in Gitea (both must match or both blank).
GITEA_WEBHOOK_SECRET=

# ── Webhook URL (for reference — paste this into Gitea webhook settings) ──────
# http://tuskersquad-integration:8001/gitea/webhook
# IMPORTANT: use the container name (tuskersquad-integration), NOT localhost.
# Gitea runs inside Docker so localhost resolves to the Gitea container itself.

# ── Auto-Merge & Deploy ───────────────────────────────────────────────
AUTO_MERGE_ON_APPROVE=false
MERGE_STYLE=merge
DEPLOY_ON_MERGE=false
DEPLOY_BRANCH=main
DEPLOY_PIPELINE=deploy

# ── Demo bug flags ────────────────────────────────────────────────────
# Set to true to inject bugs for TuskerSquad agents to detect
BUG_PRICE=false
BUG_SECURITY=false
BUG_SLOW=false

# ── ShopFlow v2 microservice bug flags ─────────────────────────────────────────
# catalog-service bugs
BUG_INVENTORY=false        # Reports inflated stock counts (oversell risk)
BUG_PRICE_RULE=false       # Applies incorrect 35% VAT multiplier on catalog prices

# order-service bugs
BUG_NO_ROLLBACK=false      # Does not roll back stock reservation on payment failure

# user-service bugs
BUG_JWT_NO_EXPIRY=false    # Issues JWTs with no exp claim (tokens valid forever)
BUG_WEAK_PASSWORD=false    # Accepts passwords shorter than 8 characters

# ── Optional integrations ─────────────────────────────────────────────
JIRA_URL=
JIRA_TOKEN=
JIRA_PROJECT=TUSKER
SLACK_WEBHOOK_URL=

# ── Agent tool configuration ──────────────────────────────────────────────────
# Each agent has a configurable primary tool. Change these to use different
# testing frameworks without touching agent code.

# Backend agent — runs API/unit tests
# Options: pytest (default) | unittest | nose2
BACKEND_TEST_TOOL=pytest
# Path to backend test directory (relative to repo root inside the container)
BACKEND_TEST_DIR=tests/api
# Base URL of the demo backend service
DEMO_APP_URL=http://tuskersquad-demo-backend:8080

# ── ShopFlow v2 microservice URLs ──────────────────────────────────────────────
CATALOG_SERVICE_URL=http://tuskersquad-catalog:8081
ORDER_SERVICE_URL=http://tuskersquad-order:8082
USER_SERVICE_URL=http://tuskersquad-user:8083

# Frontend agent — runs browser/UI tests
# Options: playwright (default) | cypress | selenium
FRONTEND_TEST_TOOL=playwright
# Path to frontend test directory
PLAYWRIGHT_TEST_DIR=tests/ui
# URL of the frontend app under test
DEMO_FRONTEND_URL=http://localhost:5173

# Security agent — HTTP probe tool used for OWASP checks
# Options: httpx (default, built-in) | zap | trivy
SECURITY_PROBE_TOOL=httpx

# SRE agent — load/latency test tool
# Options: httpx (default, built-in) | k6 | locust | ab
SRE_LOAD_TOOL=httpx
# Number of requests to send per load test run
SRE_REQUEST_COUNT=10
# Latency threshold in milliseconds — findings raised above this
LATENCY_THRESHOLD_MS=500

# ─────────────────────────────────────────────────────────────────────────────
# Git Provider — Sprint 1: Multi-provider support
# ─────────────────────────────────────────────────────────────────────────────

# Which git provider to use. Gitea is the default (backward-compatible).
# Set this to match where your repos live.
# GIT_PROVIDER=gitea    ← default, uses GITEA_URL + GITEA_TOKEN
# GIT_PROVIDER=github   ← uses GITHUB_TOKEN + GITHUB_WEBHOOK_SECRET
# GIT_PROVIDER=gitlab   ← uses GITLAB_TOKEN + GITLAB_WEBHOOK_SECRET
GIT_PROVIDER=gitea

# ── GitHub ─────────────────────────────────────────────────────────────────
# Personal access token (fine-grained or classic). Required scopes:
#   repo:  read+write contents, pull requests, issues, actions
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitHub Enterprise Server base API URL (leave blank for github.com)
# GITHUB_API_URL=https://github.yourcompany.com/api/v3

# Webhook secret — set this in GitHub repo Settings > Webhooks > Secret
# Must match the value you enter in GitHub. Keep it secret.
GITHUB_WEBHOOK_SECRET=

# GitHub Actions workflow file to dispatch on merge (default: deploy.yml)
# GITHUB_ACTIONS_WORKFLOW=deploy.yml

# ── GitLab ──────────────────────────────────────────────────────────────────
# Personal access token or project access token. Required scope: api
# Generate at: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=

# Self-hosted GitLab base URL (leave blank for gitlab.com)
# GITLAB_URL=https://gitlab.yourcompany.com

# Webhook secret token — set this in GitLab project Settings > Webhooks
GITLAB_WEBHOOK_SECRET=

# Pipeline trigger token (for triggering CI pipelines on merge)
# Generate at: GitLab project Settings > CI/CD > Pipeline triggers
# GITLAB_TRIGGER_TOKEN=

# ── Webhook URLs (for reference) ────────────────────────────────────────────
# Point your git provider's webhook to these URLs:
#
#   Gitea:  POST http://<host>:8001/gitea/webhook
#   GitHub: POST http://<host>:8001/github/webhook
#   GitLab: POST http://<host>:8001/gitlab/webhook
#
# For GitHub/GitLab to reach a local install, use ngrok or a public host.
# Example with ngrok:
#   ngrok http 8001
#   → use the https://xxxx.ngrok.io/github/webhook URL in GitHub settings
