# ════════════════════════════════════════════════════════════════════
# TuskerSquad — Environment Variables
# Copy: cp infra/.env.example infra/.env
# ════════════════════════════════════════════════════════════════════

# ── Ollama (LLM backend) ─────────────────────────────────────────────
# Mac/Windows: host.docker.internal resolves automatically.
# Linux: replace with your host IP, e.g. http://192.168.1.100:11434
OLLAMA_URL=http://host.docker.internal:11434

# ── Gitea integration (optional) ─────────────────────────────────────
# Generate at: http://localhost:3000/user/settings/applications
GITEA_TOKEN=

# ── Auto-Merge & Deploy (optional) ───────────────────────────────────
AUTO_MERGE_ON_APPROVE=false
MERGE_STYLE=merge
DEPLOY_ON_MERGE=false
DEPLOY_BRANCH=main
DEPLOY_PIPELINE=deploy

# ── Demo bug flags (set true to inject bugs for TuskerSquad to detect)
# BUG_PRICE inflates checkout totals by 35%
BUG_PRICE=false
# BUG_SECURITY bypasses JWT authentication
BUG_SECURITY=false
# BUG_SLOW adds a 3-second sleep on every checkout request
BUG_SLOW=false

# ── Optional integrations ─────────────────────────────────────────────
JIRA_URL=
JIRA_TOKEN=
JIRA_PROJECT=TUSKER
SLACK_WEBHOOK_URL=
