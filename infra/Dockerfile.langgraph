FROM python:3.11-slim

# Install system deps needed by psycopg2-binary and compilation
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl vim \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies first (better layer caching)
COPY services/langgraph_api/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# Copy full project so all packages are importable
COPY . /app

# PYTHONPATH=/app lets Python find:
#   - services.langgraph_api.*   (the main service)
#   - agents.*                   (all agent modules)
#   - core.*                     (llm_client, model_router)
#   - apps.*                     (demo app, for test probes)
ENV PYTHONPATH=/app

CMD ["uvicorn", "services.langgraph_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
