FROM python:3.11

# Use /app as the workspace so multiple services under /app/services
# can be served by uvicorn commands issued by docker-compose.
WORKDIR /app

# Copy entire project so `services.integration_service` and other
# packages are available inside the container.
COPY . /app

# Install Python requirements for the LangGraph service (the file
# lives under services/langgraph_api/requirements.txt)
RUN pip install --no-cache-dir -r services/langgraph_api/requirements.txt

# Ensure Python can import the service packages by placing project root
# on PYTHONPATH. Adding the specific service path can mask package
# imports and break relative imports, so keep only the workspace root.
ENV PYTHONPATH=/app

# Default command serves the LangGraph API; other services override
# the command in docker-compose (for example, integration-service).
CMD ["uvicorn", "services.langgraph_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
