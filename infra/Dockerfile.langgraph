# ── TuskerSquad: LangGraph API / Dashboard / Integration ──────────────────────
FROM python:3.11-slim

# System deps:
#   gcc, libffi-dev  → bcrypt / cryptography wheels
#   libpq-dev        → psycopg2-binary fallback headers
#   curl             → useful for manual healthchecks
RUN apt-get update \
 && apt-get install -y --no-install-recommends gcc libffi-dev libpq-dev vim curl \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 1. Upgrade pip
RUN pip install --no-cache-dir --upgrade pip==24.3.1

# 2. Install Python deps (cached layer)
COPY services/langgraph_api/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# 3. Copy ALL source (PYTHONPATH=/app exposes agents/, core/, services/, config/)
COPY . /app

# Create log dir (also created at runtime, but good to have for volume mount)
RUN mkdir -p /app/logs

ENV PYTHONPATH=/app

HEALTHCHECK --interval=10s --timeout=5s --start-period=40s --retries=10 \
  CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/health', timeout=4)"

CMD ["uvicorn", "services.langgraph_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
