# ── TuskerSquad: LangGraph API / Dashboard / Integration ──────────────────────
FROM python:3.11-slim

# System deps:
#   gcc, libffi-dev  → compile bcrypt / cryptography C extensions
#   libpq-dev        → psycopg2-binary headers
#   curl, gnupg      → used below to add Docker's apt repo
#   git              → builder_agent and repo_validator_agent clone PRs
#
# Docker CLI (docker-ce-cli):
#   Required by builder_agent, deployer_agent, and cleanup_agent to build images,
#   run ephemeral containers, and clean up. We install from Docker Inc's official
#   apt repository because docker.io (the Debian-packaged version) is not available
#   in Debian 12 Bookworm — the base image for python:3.11-slim.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        gcc libffi-dev libpq-dev curl git ca-certificates gnupg \
 && install -m 0755 -d /etc/apt/keyrings \
 && curl -fsSL https://download.docker.com/linux/debian/gpg \
        | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
 && chmod a+r /etc/apt/keyrings/docker.gpg \
 && . /etc/os-release \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian ${VERSION_CODENAME} stable" \
        > /etc/apt/sources.list.d/docker.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends docker-ce-cli \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 1. Upgrade pip (pinned version — avoids pip resolver regressions)
RUN pip install --no-cache-dir --upgrade pip==24.3.1

# 2. Install Python deps first (cached layer — only rebuilds when requirements change)
COPY services/langgraph_api/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# 3. Copy all source code
#    PYTHONPATH=/app means: agents/, core/, services/, config/ are all importable
COPY . /app

# 4. Ensure log directory exists for LLM conversation logging volume mount
RUN mkdir -p /app/logs

ENV PYTHONPATH=/app

HEALTHCHECK --interval=10s --timeout=5s --start-period=40s --retries=10 \
  CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/health', timeout=4)"

CMD ["uvicorn", "services.langgraph_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
